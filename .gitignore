# ================================================ #
#  Unity .gitignore
# ================================================ #

# --- OS generated files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- IDE / Editors ---
.idea/
.vs/
.vscode/
*.sln
*.csproj
*.userprefs
*.user
*.suo
*.pidb

# --- Rider ---
.idea/

# --- Unity generated ---
[TLl]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/

# --- Asset meta data (don't ignore .meta files in packages) ---
# .meta files should generally be tracked, but not inside these folders:
[Tt]emp/**/*.meta
[Ll]ibrary/**/*.meta

# --- Autogenerated files ---
*.apk
*.aab
*.unitypackage
*.app

# --- Crashlytics ---
CrashlyticsBuildLog.csv

# --- Visual Studio cache directory ---
.vs/

# --- Gradle (Android) ---
gradle/
gradlew
gradlew.bat

# --- macOS ---
*.app

# ================================================ #
#  Node.js (for package.json / tooling)
# ================================================ #
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ================================================ #
#  Unity Package Manager specifics
# ================================================ #
# The .meta files in the package source ARE tracked.
# But we ignore meta files generated inside Library/ and Temp/ above.
